# ─── StadiumGenius Server Environment Variables ───
# Copy this file to .env and fill in the values.
# NEVER commit .env files to source control.

# ── Node.js Express Server (port 5000) ──
PORT=5000
NODE_ENV=development
JWT_SECRET=         # REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_EXPIRES_IN=7d

# ── Python FastAPI Server (port 8000) ──
ENVIRONMENT=development          # development | staging | production
DATABASE_URL=sqlite:///./stadiumgenius.db
SECRET_KEY=                      # REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
CSRF_SECRET=                     # REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"

# ── Auth0 Configuration ──
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.stadiumgenius.io
AUTH0_ISSUER=https://your-tenant.us.auth0.com/
